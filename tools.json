[
  {
    "name": "echo",
    "description": "Echo a message",
    "command": "echo",
    "arguments": [
      "{message}"
    ],
    "parameters": [
      {
        "name": "message",
        "type": "string",
        "required": true
      }
    ],
    "timeout_ms": 5000
  },
  {
    "name": "rustc-version",
    "description": "Print the installed Rust compiler version",
    "command": "rustc",
    "arguments": ["--version"],
    "parameters": [],
    "timeout_ms": 5000
  }
]