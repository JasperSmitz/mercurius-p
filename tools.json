    "category": "storage"
  },
  {
    "name": "home-folder-sizes",
    "description": "Show the largest folders in the user's home directory",
    "command": "sh",
    "arguments": [
      "-c",
      "du -h --max-depth=1 \"$HOME\" | sort -hr | head -n 30"
    ],
    "parameters": [],
    "timeout_ms": 15000,
    "read_only": true,
    "category": "storage"
  },
  {
    "name": "large-files",
    "description": "Find large files under an allowed absolute directory",
    "command": "find",
    "arguments": [
      "{path}",
      "-type",
      "f",
      "-size",
      "+{min_size_mb}M",
      "-printf",
      "%s %p\\n"
    ],
    "parameters": [
      {
        "name": "path",
        "type": "path",
        "required": true
      },
      {
        "name": "min_size_mb",
        "type": "integer",
        "required": false,
        "default": 500
      }
    ],
    "timeout_ms": 15000,
    "read_only": true,
    "category": "storage"
  },
  {
    "name": "directory-size",
