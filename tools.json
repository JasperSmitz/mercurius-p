  },
  {
    "name": "top-cpu-processes",
    "description": "Show the processes currently using the most CPU",
    "command": "sh",
    "arguments": [
      "-c",
      "ps -eo pid,ppid,comm,%cpu,%mem --sort=-%cpu | head -n 20"
    ],
    "parameters": [],
    "timeout_ms": 3000,
    "read_only": true,
    "category": "system"
  },
  {
    "name": "top-memory-processes",
    "description": "Show the processes currently using the most memory",
    "command": "sh",
    "arguments": [
      "-c",
      "ps -eo pid,comm,rss,%mem --sort=-rss | head -n 25"
    ],
    "parameters": [],
    "timeout_ms": 3000,
    "read_only": true,
    "category": "system"
  },
  {
    "name": "process-search",
    "description": "Search for running processes by name or command text",
    "command": "pgrep",
    "arguments": ["-af", "{query}"],
    "parameters": [
      {
        "name": "query",
        "type": "string",
        "required": true
      }
    ],
    "timeout_ms": 3000,
    "read_only": true,
    "category": "system"
  },
  {
    "name": "disk-overview",
    "description": "Show disk usage for mounted filesystems",
